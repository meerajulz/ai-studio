// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum MediaType {
  IMAGE
  VIDEO
}

enum GenerationStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

// Identity lifecycle (Decision 027): new identities start DRAFT; adding training media
// auto-promotes to ACTIVE; removing all training media returns to DRAFT; ARCHIVED is explicit.
enum IdentityStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Standardized training-media roles (Decision 027). Stored now; no AI behavior built on them yet.
enum TrainingMediaRole {
  PRIMARY
  SECONDARY
  VIDEO
  POSE
  STYLE
  OTHER
}

// Identity Engine (Milestone 22) — lifecycle of a trained identity model (LoRA, …). Append-only
// versioning: a model is never overwritten, so status tracks a single version's state.
enum TrainedModelStatus {
  DRAFT
  READY
  FAILED
  ARCHIVED
}

// ============================================================
// Auth
// Auth models (User/Session/Account/Verification) follow the Better Auth
// core schema. Domain relations (projects, generations, …) hang off User.
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  projects        Project[]
  identities      Identity[]
  uploads         UploadedMedia[]
  generations     Generation[]
  generatedMedia  GeneratedMedia[]
  templates       Template[]
  favoritePrompts FavoritePrompt[]
  jobs            Job[]

  // Identity Engine (Milestone 22) — owner back-relations.
  identityDatasets      IdentityDataset[]
  identityTrainedModels IdentityTrainedModel[]
  identityTrainingJobs  IdentityTrainingJob[]
  identityEvaluations   IdentityEvaluation[]
  identityArtifacts     IdentityArtifact[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ============================================================
// Domain
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  identities     Identity[]
  uploads        UploadedMedia[]
  generations    Generation[]
  generatedMedia GeneratedMedia[]

  @@index([userId])
}

model Identity {
  id          String         @id @default(cuid())
  name        String
  description String? // short human summary (shown on cards/overview)
  notes       String? // longer private notes
  status      IdentityStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Project-scoped for the MVP (Decision 027): required + cascade.
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Hero Image (UX name) — one of this identity's training media. SetNull if that media is deleted.
  displayImageId String?
  displayImage   UploadedMedia? @relation("IdentityHeroImage", fields: [displayImageId], references: [id], onDelete: SetNull)

  trainingMedia IdentityMedia[]
  generations   Generation[]

  // Identity Engine (Milestone 22) — dataset readiness, versioned trained models, training jobs,
  // evaluations, and generic identity artifacts (LoRAs/embeddings/adapters/vectors).
  dataset       IdentityDataset?
  trainedModels IdentityTrainedModel[]
  trainingJobs  IdentityTrainingJob[]
  evaluations   IdentityEvaluation[]
  artifacts     IdentityArtifact[]

  @@index([userId])
  @@index([projectId])
  @@index([displayImageId])
}

// Join: which media (images + videos) trains/represents an identity, with per-link metadata.
// Curated LINKS into the media layer — deleting a link never deletes the underlying media.
model IdentityMedia {
  id         String            @id @default(cuid())
  position   Int               @default(0) // display/order within the identity
  isFavorite Boolean           @default(false)
  role       TrainingMediaRole @default(OTHER)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  mediaId String
  media   UploadedMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([identityId, mediaId])
  @@index([identityId])
  @@index([mediaId])
}

model UploadedMedia {
  id               String    @id @default(cuid())
  type             MediaType
  blobUrl          String // raw (private) blob URL — used for deletion
  pathname         String // blob key within the store — used to sign view URLs
  originalFilename String? // the file name the user uploaded
  mimeType         String?
  width            Int? // images + videos
  height           Int?
  durationSeconds  Int? // videos
  sizeBytes        Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Training-media links (an asset can train multiple identities) + hero-image back-relation.
  trainingLinks     IdentityMedia[]
  heroForIdentities Identity[]      @relation("IdentityHeroImage")

  // Persisted Vision knowledge for this image (Milestone 20) — analyzed once, reused everywhere.
  visionKnowledge MediaVisionKnowledge?

  @@index([userId])
  @@index([projectId])
}

/**
 * Persisted, PROVIDER-NEUTRAL Vision knowledge for one image (Milestone 20). Analyzed once (on demand
 * / manual reanalyze), never at generation time. Stores only the frozen `im-2` knowledge — NEVER raw
 * Gemini responses, provider-specific JSON, or transient debug values. 1:1 with UploadedMedia.
 */
model MediaVisionKnowledge {
  id           String   @id @default(cuid())
  version      String // IDENTITY_METADATA_VERSION at analysis (e.g. "im-2")
  provider     String // e.g. "gemini"
  model        String // e.g. "gemini-flash-latest"
  overallScore Int // denormalized IdentityImageScore.overall — fast ranking/sort
  metadata     Json // frozen im-2 IdentityMetadata (includes quality + referenceSuitability)
  score        Json // IdentityImageScore
  analyzedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  mediaId String        @unique
  media   UploadedMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)
}

model Generation {
  id        String           @id @default(cuid())
  type      MediaType
  prompt    String
  provider  String // e.g. "flux", "veo" — string, not enum (provider-agnostic)
  model     String
  params    Json? // provider-specific settings
  status    GenerationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  job         Job?
  results     GeneratedMedia[]
  evaluations IdentityEvaluation[] // Identity Engine (Milestone 22) — identity score of a result

  @@index([userId])
  @@index([projectId])
  @@index([identityId])
  @@index([status])
}

model GeneratedMedia {
  id               String    @id @default(cuid())
  type             MediaType
  blobUrl          String // raw (private) blob URL — used for deletion
  pathname         String // blob key within the store — used to sign view URLs
  originalFilename String? // a friendly name for the output
  mimeType         String?
  width            Int?
  height           Int?
  durationSeconds  Int? // videos
  sizeBytes        Int?
  createdAt        DateTime  @default(now())

  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  // Project scoping so generated media surfaces in the project Gallery (Decision 029).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([projectId])
  @@index([userId])
}

model Job {
  id            String    @id @default(cuid())
  status        JobStatus @default(PENDING)
  progress      Int       @default(0) // 0..100
  attempts      Int       @default(0)
  providerJobId String? // id returned by the AI provider
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  generationId String     @unique
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  prompt      String
  config      Json? // reusable prompt options (style, camera, lighting, …)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  generations Generation[]

  @@index([userId])
}

model FavoritePrompt {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// Identity Engine (Milestone 22) — Identity as its own subsystem.
// All additive; the current Reference-only flow is unchanged. Generation consumes the Identity
// Engine and never learns how an identity is implemented (reference / LoRA / adapter). Training,
// evaluation and adapters are ARCHITECTURE ONLY here — no LoRA/PuLID/InstantID/ML implementation.
// ============================================================

/// Persisted dataset readiness for an Identity. Computed from the identity's persisted Vision
/// knowledge when its library is (re)analyzed — never at generation time. 1:1 with Identity.
/// Curation fields are reserved for future training (which curated revision a trainer consumes).
model IdentityDataset {
  id             String   @id @default(cuid())
  readinessScore Int      @default(0) // 0..100 — "this score becomes part of the Identity"
  rating         String   @default("poor") // excellent | good | fair | poor
  imageCount     Int      @default(0)
  analyzedCount  Int      @default(0)
  metrics        Json // DatasetMetrics (coverage + diversity/quality)
  version        String // metrics-engine version (e.g. "de-1")
  computedAt     DateTime @default(now())

  // Curation metadata (reserved for training).
  datasetVersion      Int      @default(1) // curated revision a trainer consumes
  recommendedImageIds String[]
  rejectedImageIds    String[]
  rejectionReasons    Json? // { [mediaId]: reason }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identityId String   @unique
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// A versioned trained identity model (architecture only — no training yet). Append-only: never
/// overwrite — every run creates a new version (LoRA v1, v2, …). Provider-agnostic.
model IdentityTrainedModel {
  id                 String             @id @default(cuid())
  engine             String // "lora" | future engines
  provider           String // "fal" | … (provider-agnostic)
  version            Int // per (identity, engine) — never reused
  label              String
  status             TrainedModelStatus @default(DRAFT)
  triggerWord        String?
  artifactRef        String? // blob key / url of the weights (null until trained)
  modelCompatibility String[] // base models this adapter is compatible with
  cost               Float?
  durationSeconds    Int?
  params             Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trainingJobs IdentityTrainingJob[]

  @@unique([identityId, engine, version])
  @@index([identityId])
  @@index([userId])
}

/// A training run (architecture only). Provider-agnostic; the first backend will be Fal.
model IdentityTrainingJob {
  id             String    @id @default(cuid())
  engine         String
  provider       String
  status         JobStatus @default(PENDING)
  providerJobId  String?
  datasetVersion Int
  triggerWord    String?
  params         Json?
  cost           Float?
  error          String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  trainedModelId String?
  trainedModel   IdentityTrainedModel? @relation(fields: [trainedModelId], references: [id], onDelete: SetNull)

  @@index([identityId])
  @@index([userId])
  @@index([status])
}

/// Identity evaluation of a generated image (architecture only — no ML yet). All metric slots are
/// reserved now (null today) so future evaluators fill them without a schema change.
model IdentityEvaluation {
  id                   String   @id @default(cuid())
  face                 Float?
  tattoos              Float?
  hair                 Float?
  accessories          Float?
  pose                 Float?
  expression           Float?
  lighting             Float?
  composition          Float?
  overallIdentityScore Float?
  method               String   @default("not-configured")
  metrics              Json?
  createdAt            DateTime @default(now())

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  generationId String?
  generation   Generation? @relation(fields: [generationId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@index([generationId])
  @@index([userId])
}

/// A generic, versioned identity resource. Stores LoRAs, embeddings, adapter files, vectors, and
/// other generated identity artifacts — not only media. Gives non-trainable engines (PuLID/InstantID)
/// a home for precomputed artifacts, so the schema supports trainable AND non-trainable engines.
model IdentityArtifact {
  id        String   @id @default(cuid())
  kind      String // "lora" | "embedding" | "id-vector" | "adapter" | …
  engine    String?
  version   Int      @default(1)
  ref       String // blob key / url
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([identityId])
  @@index([userId])
}
