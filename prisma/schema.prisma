// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Enums
// ============================================================

enum MediaType {
  IMAGE
  VIDEO
}

enum GenerationStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

// Identity lifecycle (Decision 027): new identities start DRAFT; adding training media
// auto-promotes to ACTIVE; removing all training media returns to DRAFT; ARCHIVED is explicit.
enum IdentityStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

// Standardized training-media roles (Decision 027). Stored now; no AI behavior built on them yet.
enum TrainingMediaRole {
  PRIMARY
  SECONDARY
  VIDEO
  POSE
  STYLE
  OTHER
}

// ============================================================
// Auth
// Auth models (User/Session/Account/Verification) follow the Better Auth
// core schema. Domain relations (projects, generations, …) hang off User.
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  projects        Project[]
  identities      Identity[]
  uploads         UploadedMedia[]
  generations     Generation[]
  generatedMedia  GeneratedMedia[]
  templates       Template[]
  favoritePrompts FavoritePrompt[]
  jobs            Job[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

// ============================================================
// Domain
// ============================================================

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  identities     Identity[]
  uploads        UploadedMedia[]
  generations    Generation[]
  generatedMedia GeneratedMedia[]

  @@index([userId])
}

model Identity {
  id          String         @id @default(cuid())
  name        String
  description String? // short human summary (shown on cards/overview)
  notes       String? // longer private notes
  status      IdentityStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Project-scoped for the MVP (Decision 027): required + cascade.
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Hero Image (UX name) — one of this identity's training media. SetNull if that media is deleted.
  displayImageId String?
  displayImage   UploadedMedia? @relation("IdentityHeroImage", fields: [displayImageId], references: [id], onDelete: SetNull)

  trainingMedia IdentityMedia[]
  generations   Generation[]

  @@index([userId])
  @@index([projectId])
  @@index([displayImageId])
}

// Join: which media (images + videos) trains/represents an identity, with per-link metadata.
// Curated LINKS into the media layer — deleting a link never deletes the underlying media.
model IdentityMedia {
  id         String            @id @default(cuid())
  position   Int               @default(0) // display/order within the identity
  isFavorite Boolean           @default(false)
  role       TrainingMediaRole @default(OTHER)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  identityId String
  identity   Identity @relation(fields: [identityId], references: [id], onDelete: Cascade)

  mediaId String
  media   UploadedMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([identityId, mediaId])
  @@index([identityId])
  @@index([mediaId])
}

model UploadedMedia {
  id               String    @id @default(cuid())
  type             MediaType
  blobUrl          String // raw (private) blob URL — used for deletion
  pathname         String // blob key within the store — used to sign view URLs
  originalFilename String? // the file name the user uploaded
  mimeType         String?
  width            Int? // images + videos
  height           Int?
  durationSeconds  Int? // videos
  sizeBytes        Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Training-media links (an asset can train multiple identities) + hero-image back-relation.
  trainingLinks     IdentityMedia[]
  heroForIdentities Identity[]      @relation("IdentityHeroImage")

  @@index([userId])
  @@index([projectId])
}

model Generation {
  id        String           @id @default(cuid())
  type      MediaType
  prompt    String
  provider  String // e.g. "flux", "veo" — string, not enum (provider-agnostic)
  model     String
  params    Json? // provider-specific settings
  status    GenerationStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  identityId String?
  identity   Identity? @relation(fields: [identityId], references: [id], onDelete: SetNull)

  templateId String?
  template   Template? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  job     Job?
  results GeneratedMedia[]

  @@index([userId])
  @@index([projectId])
  @@index([identityId])
  @@index([status])
}

model GeneratedMedia {
  id               String    @id @default(cuid())
  type             MediaType
  blobUrl          String // raw (private) blob URL — used for deletion
  pathname         String // blob key within the store — used to sign view URLs
  originalFilename String? // a friendly name for the output
  mimeType         String?
  width            Int?
  height           Int?
  durationSeconds  Int? // videos
  sizeBytes        Int?
  createdAt        DateTime  @default(now())

  generationId String
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  // Project scoping so generated media surfaces in the project Gallery (Decision 029).
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([generationId])
  @@index([projectId])
  @@index([userId])
}

model Job {
  id            String    @id @default(cuid())
  status        JobStatus @default(PENDING)
  progress      Int       @default(0) // 0..100
  attempts      Int       @default(0)
  providerJobId String? // id returned by the AI provider
  error         String?
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  generationId String     @unique
  generation   Generation @relation(fields: [generationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  prompt      String
  config      Json? // reusable prompt options (style, camera, lighting, …)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  generations Generation[]

  @@index([userId])
}

model FavoritePrompt {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
