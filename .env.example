# Copy to .env and fill in real values. Never commit .env.

# Database — Neon PostgreSQL (Connect dialog → Prisma / direct connection string)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Better Auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-generated-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Vercel Blob (Storage)
# Vercel dashboard → Storage → create a Blob store → copy the read/write token
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx"

# Hugging Face (AI image generation)
# huggingface.co → Settings → Access Tokens → create a token (read/inference)
# HF_TOKEN is preferred; HUGGINGFACE_API_KEY is also accepted.
HF_TOKEN="hf_xxxxxxxxxxxx"
# Optional — override the default text-to-image model:
# HF_IMAGE_MODEL="black-forest-labs/FLUX.1-schnell"

# Fal.ai (premium AI image provider — Milestone 15; identity preservation via Kontext — Milestone 17)
# fal.ai → dashboard → Keys → create a key
FAL_KEY="xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxx"
# Optional — text-to-image model (no identity / no reference images):
# FAL_IMAGE_MODEL="fal-ai/flux/schnell"
# Optional — identity-preserving models (used automatically when an identity has reference images):
# FAL_IDENTITY_MODEL="fal-ai/flux-pro/kontext"              # one reference image
# FAL_IDENTITY_MULTI_MODEL="fal-ai/flux-pro/kontext/max/multi"  # multiple reference images
# Optional — LoRA training (Milestone 24). Trainer that produces the identity LoRA:
# FAL_LORA_TRAINER_MODEL="fal-ai/flux-lora-portrait-trainer"
# (Reference + LoRA generation uses fal-ai/flux-kontext-lora automatically when a trained model exists.)

# Optional — force a specific image provider (else the router auto-selects, premium first).
# Useful for verifying Hugging Face still works. Values: "fal" | "huggingface".
# IMAGE_PROVIDER="fal"

# Google Gemini (Vision — Identity Intelligence, Milestone 19; image UNDERSTANDING, not generation)
# aistudio.google.com → Get API key. Used to analyze identity images into structured knowledge.
# GEMINI_API_KEY="AIza..."
# Optional — override the vision model. Default is the rolling alias "gemini-flash-latest".
# If your key returns 404 for a model, open /debug/vision → "List models" to see valid ids.
# GEMINI_VISION_MODEL="gemini-flash-latest"
# Optional — force a specific vision provider (else the router auto-selects). Values: "gemini".
# VISION_PROVIDER="gemini"
